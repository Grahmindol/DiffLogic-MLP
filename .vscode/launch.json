{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/main",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,

      "MIMode": "gdb",

      "linux": {
        "miDebuggerPath": "/usr/bin/gdb"
      },

      "osx": {
        "MIMode": "lldb"
      },

      "windows": {
        "program": "${workspaceFolder}/build/main.exe",
        "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe"
      },

      "setupCommands": [
        {
          "description": "Enable pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],

      "preLaunchTask": "Debug Build"
    },

    {
      "name": "Release Run",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/main",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,

      "MIMode": "gdb",

      "linux": {
        "miDebuggerPath": "/usr/bin/gdb"
      },

      "osx": {
        "MIMode": "lldb"
      },

      "windows": {
        "program": "${workspaceFolder}/build/main.exe",
        "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe"
      },

      "setupCommands": [
        {
          "description": "Enable pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],

      "preLaunchTask": "Release Build"
    }
  ]
}