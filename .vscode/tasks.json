{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "Debug Build",
      "command": "make",
      "args": [
        "-j8",
        "DEBUG=1"
      ],
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "shell",
      "label": "Release Build",
      "command": "make",
      "args": [
        "-j8",
        "DEBUG=0"
      ],
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "type": "shell",
      "label": "Clean",
      "command": "make",
      "args": [
        "clean"
      ],
      "problemMatcher": []
    }
  ]
}